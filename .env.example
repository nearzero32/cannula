# Copy to .env and fill in values:
#   cp .env.example .env

# ── Auth (required) ──────────────────────────────────────────────
ACCESS_TOKEN_SECRET=change-me-use-long-random-string
REFRESH_TOKEN_SECRET=change-me-use-different-long-random-string

# ── MongoDB (required) ───────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/cannula
# Or embed credentials in the URI:
# MONGODB_URI=mongodb://user:password@host:27017/cannula
# Optional separate credentials (appended to MONGODB_URI when set):
# MONGODB_USER=
# MONGODB_PASSWORD=
# MONGODB_MAX_POOL_SIZE=10
# MONGODB_MIN_POOL_SIZE=5
# MONGODB_MAX_IDLE_TIME_MS=30000
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
# MONGODB_SOCKET_TIMEOUT_MS=45000

# ── Redis (required) ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_USERNAME=
# REDIS_DATABASE=0
# REDIS_TLS=false

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated origins; omit to allow all (dev only)
# ALLOWED_ORIGINS=http://localhost:5173,https://your-app.com

# ── Super admin (first boot seed) ────────────────────────────────
# If unset, migration uses built-in defaults (change in production)
# SUPER_ADMIN_PHONE=07700000000
# SUPER_ADMIN_PASSWORD=123456
# SUPER_ADMIN_FULL_NAME=Super Admin
# SUPER_ADMIN_EMAIL=admin@example.com

# ── Cloudflare R2 — image uploads (optional) ─────────────────────
# Create API token: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public URL: custom domain or R2 public bucket URL
R2_PUBLIC_URL=https://cdn.example.com
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_PRESIGN_EXPIRES_IN=900
# R2_MAX_UPLOAD_BYTES=5242880

# Legacy S3-style names (fallback if R2_* not set)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET_NAME=
# AWS_S3_ENDPOINT=

# ── Push notifications — OneSignal (optional) ───────────────────
# ONESIGNAL_APP_ID=
# ONESIGNAL_API_KEY=

# ── Firebase (optional) ──────────────────────────────────────────
FIREBASE_SERVER_KEY=

# ── Email / SMTP (optional) ──────────────────────────────────────
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=

# ── Other integrations (optional) ────────────────────────────────
# REVERSE_GEOCODE_URL=https://nominatim.openstreetmap.org/reverse
# QI_UAT_PAYMENT_BASE_URL=
# QI_PAYMENT_BASE_URL=

# ── Runtime ──────────────────────────────────────────────────────
# NODE_ENV=development
