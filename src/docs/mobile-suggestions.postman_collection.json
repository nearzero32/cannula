{
  "info": {
    "name": "Kanona - Mobile Suggestions",
    "_postman_id": "b9d5f2a3-4c8e-4b9f-9d2e-3a6f7b8c9d0e",
    "description": "Mobile suggestion endpoints for authenticated patients.\n\nBase path: `/api/mobile/suggestions`\n\nSetup:\n1. Set `baseUrl` (default: http://localhost:3001/api).\n2. Register via `POST /mobile/auth/register` and save `accessToken` from the response.\n3. All requests require `Authorization: Bearer {{accessToken}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "List My Suggestions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/mobile/suggestions?page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["mobile", "suggestions"],
          "query": [
            {
              "key": "page",
              "value": "1",
              "description": "Page number (default: 1)"
            },
            {
              "key": "limit",
              "value": "10",
              "description": "Items per page (max: 100)"
            }
          ]
        },
        "description": "Returns paginated list of the authenticated user's suggestions (non-deleted only)."
      }
    },
    {
      "name": "Create Suggestion",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"suggestion\": \"أقترح إضافة تذكير بالمواعيد عبر الإشعارات قبل الموعد بـ 24 ساعة.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/mobile/suggestions",
          "host": ["{{baseUrl}}"],
          "path": ["mobile", "suggestions"]
        },
        "description": "Submit a new suggestion. `suggestion` is required (1–2000 characters)."
      }
    }
  ]
}
