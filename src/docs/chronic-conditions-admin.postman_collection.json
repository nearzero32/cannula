{
  "info": {
    "name": "Kanona - Admin Chronic Conditions",
    "_postman_id": "a8c4e1f2-9b3d-4a7e-8c1d-2f5e6a7b8c9d",
    "description": "Admin CRUD endpoints for chronic conditions.\n\nBase path: `/api/dash/admin/chronic-conditions`\n\nSetup:\n1. Set `baseUrl` (default: http://localhost:3001/api).\n2. Login via dashboard auth and set `accessToken`.\n3. Replace `{{chronic_condition_id}}` with a real MongoDB ObjectId.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "chronic_condition_id",
      "value": "665000000000000000000010",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "List Chronic Conditions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/dash/admin/chronic-conditions?page=1&limit=10&status=active&search=",
          "host": ["{{baseUrl}}"],
          "path": ["dash", "admin", "chronic-conditions"],
          "query": [
            {
              "key": "page",
              "value": "1",
              "description": "Page number (default: 1)"
            },
            {
              "key": "limit",
              "value": "10",
              "description": "Items per page (max: 100)"
            },
            {
              "key": "status",
              "value": "active",
              "description": "Filter: active | inactive"
            },
            {
              "key": "search",
              "value": "",
              "description": "Search in name and description"
            }
          ]
        },
        "description": "Paginated list of chronic conditions."
      }
    },
    {
      "name": "Get Chronic Condition By ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/dash/admin/chronic-conditions/{{chronic_condition_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["dash", "admin", "chronic-conditions", "{{chronic_condition_id}}"]
        },
        "description": "Get a single chronic condition by ID."
      }
    },
    {
      "name": "Create Chronic Condition",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"السكري\",\n  \"description\": \"مرض مزمن يؤثر على مستوى السكر في الدم\",\n  \"status\": \"active\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/dash/admin/chronic-conditions",
          "host": ["{{baseUrl}}"],
          "path": ["dash", "admin", "chronic-conditions"]
        },
        "description": "Create a new chronic condition. `status` is optional (default: active)."
      }
    },
    {
      "name": "Update Chronic Condition",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"السكري من النوع الثاني\",\n  \"description\": \"مرض مزمن يؤثر على مستوى السكر في الدم ويتطلب متابعة طبية\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/dash/admin/chronic-conditions/{{chronic_condition_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["dash", "admin", "chronic-conditions", "{{chronic_condition_id}}"]
        },
        "description": "Partial update — send only fields to change (`name`, `description`)."
      }
    },
    {
      "name": "Update Chronic Condition Status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"inactive\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/dash/admin/chronic-conditions/{{chronic_condition_id}}/status",
          "host": ["{{baseUrl}}"],
          "path": [
            "dash",
            "admin",
            "chronic-conditions",
            "{{chronic_condition_id}}",
            "status"
          ]
        },
        "description": "Activate or deactivate a chronic condition. Values: `active` | `inactive`."
      }
    }
  ]
}
